<Window x:Class="QLSanPham.ThongKe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thống Kê Danh Mục" Height="300" Width="600"
        WindowStartupLocation="CenterScreen" 
        Loaded="Window_Loaded">
    <Grid>
        <DataGrid x:Name="dgThongKe" AutoGenerateColumns="False" IsReadOnly="True" Margin="10">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    <Setter Property="Foreground" Value="Blue"/>
                    <Setter Property="Height" Value="30"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã danh mục" Binding="{Binding MaDanhMuc}" Width="100"/>
                <DataGridTextColumn Header="Tên danh mục" Binding="{Binding TenDanhMuc}" Width="150"/>
                <DataGridTextColumn Header="Số loại sản phẩm" Binding="{Binding SoLuongSanPham}" Width="150"/>
                <DataGridTextColumn Header="Tổng số lượng SP" Binding="{Binding TongSoLuong}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>