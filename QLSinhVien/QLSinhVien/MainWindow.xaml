<Window x:Class="QLSinhVien.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QLSinhVien"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Window.Resources>
        <Style TargetType="Label" x:Key="labelsp">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="Blue"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Foreground" Value="Blue"/>
            <Setter Property="FontStyle" Value="Italic"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Width" Value="85"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="#CFC"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="myheader" TargetType="DataGridColumnHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="Blue"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>

    <Canvas>
        <Label Content="QUẢN LÝ SINH VIÊN" Canvas.Left="280" Canvas.Top="14" 
               FontSize="20" FontWeight="Bold" Foreground="Blue"/>

        <Label Style="{StaticResource labelsp}" Content="Mã sinh viên" Canvas.Left="120" Canvas.Top="70"/>
        <TextBox Name="txtMaSV" Canvas.Left="250" Canvas.Top="70" Width="180" Height="25" IsReadOnly="True" Background="#EEEEEE"/>

        <Label Style="{StaticResource labelsp}" Content="Tên sinh viên" Canvas.Left="120" Canvas.Top="100"/>
        <TextBox Name="txtTenSV" Canvas.Left="250" Canvas.Top="100" Width="180" Height="25"/>

        <Label Style="{StaticResource labelsp}" Content="Ngày sinh" Canvas.Left="120" Canvas.Top="130"/>
        <DatePicker Name="dpNgaySinh" Canvas.Left="250" Canvas.Top="130" Width="180" Height="25"/>

        <Label Style="{StaticResource labelsp}" Content="Giới tính" Canvas.Left="120" Canvas.Top="160"/>
        <StackPanel Canvas.Left="250" Canvas.Top="160" Orientation="Horizontal" Width="180" Height="25" VerticalAlignment="Center">
            <RadioButton Name="rbNam" Content="Nam" Margin="0,5,20,0" IsChecked="True"/>
            <RadioButton Name="rbNu" Content="Nữ" Margin="0,5,0,0"/>
        </StackPanel>

        <Label Style="{StaticResource labelsp}" Content="Địa chỉ" Canvas.Left="120" Canvas.Top="190"/>
        <ComboBox Name="cbDiaChi" Canvas.Left="250" Canvas.Top="190" Width="180" Height="25"/>

        <DataGrid x:Name="dgDanhSachSV" Height="240" Width="680" AutoGenerateColumns="False"
                  Canvas.Left="60" Canvas.Top="240" ColumnHeaderStyle="{StaticResource myheader}" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SV" Binding="{Binding MaSV}" Width="80"/>
                <DataGridTextColumn Header="Tên sinh viên" Binding="{Binding TenSV}" Width="180"/>
                <DataGridTextColumn Header="Ngày sinh" Binding="{Binding NgaySinh, StringFormat=dd/MM/yyyy}" Width="120"/>
                <DataGridTextColumn Header="Giới tính" Binding="{Binding GioiTinh}" Width="100"/>
                <DataGridTextColumn Header="Địa chỉ" Binding="{Binding TenDiaChi}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Content="Thêm" Canvas.Left="150" Canvas.Top="500" Click="btnThem_Click"/>
        <Button Content="Thống kê" Canvas.Left="350" Canvas.Top="500" Click="btnThongKe_Click" Width="100"/>
        <Button Content="Đóng" Canvas.Left="550" Canvas.Top="500" Click="btnDong_Click"/>
    </Canvas>
</Window>
